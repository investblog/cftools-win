<Page
  x:Class="CFTools.Views.AddDomainsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:models="using:CFTools.Models"
  NavigationCacheMode="Required"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ProgressBar
      Grid.Row="0"
      IsIndeterminate="True"
      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
    />

    <Grid Grid.Row="1" Padding="16" RowSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Add Domains" Style="{StaticResource TitleTextBlockStyle}" />

      <StackPanel Grid.Row="1">
        <TextBlock
          Text="{x:Bind ViewModel.AccountContextText, Mode=OneWay}"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          TextWrapping="WrapWholeWords"
          Visibility="{x:Bind ViewModel.IsAccountMissing, Mode=OneWay, Converter={StaticResource InvertBoolToVisConverter}}"
        />
        <HyperlinkButton
          Content="Connect and select an account to get started"
          Padding="0"
          Click="GoToAuth_Click"
          Visibility="{x:Bind ViewModel.IsAccountMissing, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        />
      </StackPanel>

      <TextBlock
        Grid.Row="2"
        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        TextWrapping="WrapWholeWords"
      />

      <Grid x:Name="TwoColumnGrid" Grid.Row="3" RowSpacing="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition x:Name="ResultsRow" Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition x:Name="ResultsColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <TextBox
          Grid.Row="0"
          Grid.Column="0"
          Header="Paste domains from any source"
          PlaceholderText="Paste anything: plain list, CSV, HTML,&#x0a;email text, URLs, tables — domains&#x0a;will be extracted automatically.&#x0a;&#x0a;IDN/Punycode supported (例え.jp → xn--).&#x0a;Subdomains filtered to root domains.&#x0a;Duplicates detected."
          AcceptsReturn="True"
          TextWrapping="Wrap"
          IsEnabled="{x:Bind ViewModel.CanCheck, Mode=OneWay}"
          Text="{x:Bind ViewModel.DomainInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        />

        <ListView
          x:Name="ResultsList"
          Grid.Row="1"
          Grid.Column="0"
          Header="Preflight Results"
          ItemsSource="{x:Bind ViewModel.PreflightResults, Mode=OneWay}"
          SelectionMode="None"
        >
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="models:PreflightEntry">
              <Grid ColumnSpacing="6" Padding="0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  Grid.Column="0"
                  Text="{x:Bind Domain}"
                  VerticalAlignment="Center"
                  TextTrimming="CharacterEllipsis"
                  ToolTipService.ToolTip="{x:Bind Domain, Converter={StaticResource PunycodeTooltipConverter}}"
                />
                <Border
                  Grid.Column="1"
                  Background="{x:Bind Status, Converter={StaticResource PreflightBgConverter}}"
                  CornerRadius="4"
                  Padding="8,2"
                  VerticalAlignment="Center"
                  ToolTipService.ToolTip="{x:Bind Message}"
                >
                  <TextBlock
                    Text="{x:Bind Status, Converter={StaticResource PreflightTextConverter}}"
                    Foreground="{x:Bind Status, Converter={StaticResource PreflightFgConverter}}"
                    FontSize="11"
                    FontWeight="SemiBold"
                  />
                </Border>
                <Button
                  Grid.Column="2"
                  Click="RemoveDomain_Click"
                  Tag="{x:Bind Domain}"
                  Padding="4"
                  MinWidth="0"
                  MinHeight="0"
                  Background="Transparent"
                  BorderBrush="Transparent"
                  ToolTipService.ToolTip="Remove from list"
                  Visibility="{x:Bind Status, Converter={StaticResource WillCreateToVisConverter}}"
                >
                  <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>

      <StackPanel
        Grid.Row="4"
        Spacing="8"
        Visibility="{x:Bind ViewModel.ShowProgress, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
      >
        <ProgressBar
          Minimum="0"
          Maximum="{x:Bind ViewModel.ProgressMaximum, Mode=OneWay}"
          Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
        />
        <TextBlock
          Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        />
      </StackPanel>

      <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8">
        <Button
          x:Name="CheckBtn"
          Content="Check"
          Style="{StaticResource AccentButtonStyle}"
          Command="{x:Bind ViewModel.CheckCommand}"
          IsEnabled="{x:Bind ViewModel.CanCheck, Mode=OneWay}"
        />
        <Button
          x:Name="CreateBtn"
          Content="Create All"
          Command="{x:Bind ViewModel.CreateAllCommand}"
          IsEnabled="{x:Bind ViewModel.CanCreate, Mode=OneWay}"
        />
        <Button
          Content="Cancel"
          Command="{x:Bind ViewModel.CancelBatchCommand}"
          Visibility="{x:Bind ViewModel.CanCancel, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
