<Page
    x:Class="CFTools.Views.AddDomainsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CFTools.Models">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Add Domains" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Domain input + results split -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Header="Paste domains (one per line or mixed text)"
                     PlaceholderText="example.com&#x0a;test.org&#x0a;foo.net"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Text="{x:Bind ViewModel.DomainInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <ListView Grid.Column="1" Header="Preflight Results"
                      ItemsSource="{x:Bind ViewModel.PreflightResults, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PreflightEntry">
                        <Grid ColumnSpacing="8" Padding="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Domain}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Status}" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Progress -->
        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                   Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Check" Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.CheckCommand}" />
            <Button Content="Create All"
                    Command="{x:Bind ViewModel.CreateAllCommand}"
                    IsEnabled="{x:Bind ViewModel.CanCreate, Mode=OneWay}" />
            <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="20" Height="20" />
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
