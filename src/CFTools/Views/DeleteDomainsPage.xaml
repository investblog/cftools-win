<Page
  x:Class="CFTools.Views.DeleteDomainsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:CFTools.ViewModels"
>
  <Grid>
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup>
        <VisualState x:Name="NarrowLayout" />
        <VisualState x:Name="WideLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="720" />
          </VisualState.StateTriggers>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ProgressBar
      Grid.Row="0"
      IsIndeterminate="True"
      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
    />

    <Grid Grid.Row="1" Padding="24" RowSpacing="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Delete Domains" Style="{StaticResource TitleTextBlockStyle}" />

      <TextBlock
        Grid.Row="1"
        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        TextWrapping="WrapWholeWords"
      />

      <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
        <Button Content="Select All" Command="{x:Bind ViewModel.SelectAllCommand}" />
        <Button Content="Select None" Command="{x:Bind ViewModel.SelectNoneCommand}" />
      </StackPanel>

      <ListView
        Grid.Row="3"
        ItemsSource="{x:Bind ViewModel.Zones, Mode=OneWay}"
        SelectionMode="None"
      >
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="vm:ZoneSelection">
            <Grid ColumnSpacing="8" Padding="4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <CheckBox
                Grid.Column="0"
                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                Checked="CheckBox_Changed"
                Unchecked="CheckBox_Changed"
              />
              <TextBlock Grid.Column="1" Text="{x:Bind Zone.Name}" VerticalAlignment="Center" />
              <Border
                Grid.Column="2"
                Background="{x:Bind Zone.Status, Converter={StaticResource StatusToBgConverter}}"
                CornerRadius="4"
                Padding="8,2"
                VerticalAlignment="Center"
              >
                <TextBlock
                  Text="{x:Bind Zone.Status}"
                  Foreground="{x:Bind Zone.Status, Converter={StaticResource StatusToFgConverter}}"
                  FontSize="11"
                  FontWeight="SemiBold"
                />
              </Border>
              <FontIcon
                Grid.Column="3"
                Glyph="&#xE74D;"
                Visibility="{x:Bind IsDeleted, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                Foreground="Red"
              />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <TextBlock
        Grid.Row="4"
        Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
      />

      <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8">
        <Button
          Content="Delete Selected"
          Click="DeleteButton_Click"
          IsEnabled="{x:Bind ViewModel.CanDelete, Mode=OneWay}"
          Background="#C42B1C"
          Foreground="White"
        />
        <Button
          Content="Cancel"
          Command="{x:Bind ViewModel.CancelBatchCommand}"
          Visibility="{x:Bind ViewModel.CanCancel, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
