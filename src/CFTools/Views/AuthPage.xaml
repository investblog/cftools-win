<Page
  x:Class="CFTools.Views.AuthPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:CFTools.ViewModels"
  NavigationCacheMode="Required"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ProgressBar
      Grid.Row="0"
      IsIndeterminate="True"
      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
    />

    <ScrollViewer Grid.Row="1">
      <StackPanel Padding="16" Spacing="16" MaxWidth="480" HorizontalAlignment="Left">
        <TextBlock Text="Cloudflare Authentication" Style="{StaticResource TitleTextBlockStyle}" />

        <TextBlock
          Text="Connect using your Cloudflare Global API Key."
          TextWrapping="Wrap"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        />

        <TextBox
          Header="Email"
          PlaceholderText="you@example.com"
          Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          IsEnabled="{x:Bind ViewModel.CanEditCredentials, Mode=OneWay}"
        />

        <PasswordBox
          x:Name="ApiKeyBox"
          Header="Global API Key"
          PlaceholderText="Enter your API key"
          IsEnabled="{x:Bind ViewModel.CanEditCredentials, Mode=OneWay}"
          PasswordChanged="ApiKeyBox_PasswordChanged"
        />

        <InfoBar
          IsOpen="{x:Bind ViewModel.IsStatusOpen, Mode=OneWay}"
          Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
          Severity="{x:Bind ViewModel.InfoBarSeverity, Mode=OneWay}"
          IsClosable="False"
        />

        <ComboBox
          Header="Account"
          ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
          SelectedItem="{x:Bind ViewModel.SelectedAccount, Mode=TwoWay}"
          DisplayMemberPath="Name"
          PlaceholderText="Select an account..."
          HorizontalAlignment="Stretch"
          BorderBrush="{StaticResource SystemControlHighlightAccentBrush}"
          BorderThickness="2"
          Visibility="{x:Bind ViewModel.ShowAccountPicker, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        />

        <TextBlock
          Text="Select an account to finish sign-in, or disconnect to return to the sign-in form."
          TextWrapping="Wrap"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Visibility="{x:Bind ViewModel.ShowAccountPicker, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        />

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button
            Content="Connect"
            Style="{StaticResource AccentButtonStyle}"
            Command="{x:Bind ViewModel.ConnectCommand}"
            Visibility="{x:Bind ViewModel.ShowConnectAction, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
          />
          <Button
            Content="Switch account"
            Command="{x:Bind ViewModel.SwitchAccountCommand}"
            Visibility="{x:Bind ViewModel.ShowSwitchAccountAction, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
          />
          <Button
            Content="Disconnect"
            Command="{x:Bind ViewModel.DisconnectCommand}"
            Visibility="{x:Bind ViewModel.ShowDisconnectAction, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
          />
          <Button
            Content="Forget credentials"
            Command="{x:Bind ViewModel.ForgetCommand}"
            Visibility="{x:Bind ViewModel.ShowForgetAction, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
          >
            <Button.Resources>
              <SolidColorBrush x:Key="ButtonBackground" Color="#C42B1C" />
              <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#A12316" />
              <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#861D12" />
              <SolidColorBrush x:Key="ButtonForeground" Color="White" />
              <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
              <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#CCFFFFFF" />
              <SolidColorBrush x:Key="ButtonBorderBrush" Color="#C42B1C" />
              <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#A12316" />
              <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#861D12" />
            </Button.Resources>
          </Button>
        </StackPanel>

        <StackPanel
          Spacing="8"
          Margin="0,24,0,0"
          Opacity="0.7"
          Visibility="{x:Bind ViewModel.CanEditCredentials, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        >
          <TextBlock
            Text="Where to get your API Key"
            FontWeight="SemiBold"
          />
          <TextBlock
            TextWrapping="Wrap"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          >
            <Run Text="Log in to" />
            <Hyperlink NavigateUri="https://dash.cloudflare.com/profile/api-tokens">dash.cloudflare.com</Hyperlink>
            <Run Text="→ My Profile → API Tokens → Global API Key → View." />
          </TextBlock>

          <TextBlock
            Text="Why Global API Key?"
            FontWeight="SemiBold"
            Margin="0,8,0,0"
          />
          <TextBlock
            Text="API Tokens have an undocumented quota on new accounts: you can only add as many zones as already exist. From zero — one at a time, making bulk add impossible. Global API Key has no such limit. Stored in Windows Credential Manager, sent only to the Cloudflare API."
            TextWrapping="Wrap"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
