<Page
    x:Class="CFTools.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CFTools.ViewModels">

    <StackPanel Padding="24" Spacing="16" MaxWidth="400" HorizontalAlignment="Left">
        <TextBlock Text="Cloudflare Authentication" Style="{StaticResource TitleTextBlockStyle}" />

        <TextBlock Text="Connect using your Cloudflare Global API Key."
                   TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <TextBox Header="Email" PlaceholderText="you@example.com"
                 Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <PasswordBox x:Name="ApiKeyBox" Header="Global API Key" PlaceholderText="Enter your API key"
                     PasswordChanged="ApiKeyBox_PasswordChanged" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Connect" Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.ConnectCommand}"
                    Visibility="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource InvertBoolToVisConverter}}" />
            <Button Content="Disconnect"
                    Command="{x:Bind ViewModel.DisconnectCommand}"
                    Visibility="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />
            <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="20" Height="20" />
        </StackPanel>

        <InfoBar IsOpen="{x:Bind ViewModel.IsStatusOpen, Mode=OneWay}"
                 Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.InfoBarSeverity, Mode=OneWay}" />
    </StackPanel>
</Page>
