<Page
  x:Class="CFTools.Views.PurgeCachePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:CFTools.ViewModels"
  NavigationCacheMode="Required"
>
  <Grid>
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="LayoutStates">
        <VisualState x:Name="NarrowLayout" />
        <VisualState x:Name="WideLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="720" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="NarrowToolbar.Visibility" Value="Collapsed" />
            <Setter Target="WideToolbar.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ProgressBar
      Grid.Row="0"
      IsIndeterminate="True"
      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
    />

    <Grid Grid.Row="1" Padding="16" RowSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Purge Cache" Style="{StaticResource TitleTextBlockStyle}" />

      <StackPanel Grid.Row="1">
        <TextBlock
          Text="{x:Bind ViewModel.AccountContextText, Mode=OneWay}"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          TextWrapping="WrapWholeWords"
          Visibility="{x:Bind ViewModel.IsAccountMissing, Mode=OneWay, Converter={StaticResource InvertBoolToVisConverter}}"
        />
        <HyperlinkButton
          Content="Connect and select an account to get started"
          Padding="0"
          Click="GoToAuth_Click"
          Visibility="{x:Bind ViewModel.IsAccountMissing, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        />
      </StackPanel>

      <TextBlock
        Grid.Row="2"
        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        TextWrapping="WrapWholeWords"
      />

      <Grid Grid.Row="3">
        <Grid x:Name="NarrowToolbar" RowSpacing="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBox
            Grid.Row="0"
            PlaceholderText="Filter zones..."
            Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
          />

          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button
              Content="Load Zones"
              Style="{StaticResource AccentButtonStyle}"
              Command="{x:Bind ViewModel.LoadZonesCommand}"
              IsEnabled="{x:Bind ViewModel.CanLoadZones, Mode=OneWay}"
            />
            <Button
              Content="Select All"
              Command="{x:Bind ViewModel.SelectAllCommand}"
              IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
            />
            <Button
              Content="Select None"
              Command="{x:Bind ViewModel.SelectNoneCommand}"
              IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
            />
          </StackPanel>
        </Grid>

        <StackPanel
          x:Name="WideToolbar"
          Orientation="Horizontal"
          Spacing="8"
          Visibility="Collapsed"
        >
          <Button
            Content="Load Zones"
            Style="{StaticResource AccentButtonStyle}"
            Command="{x:Bind ViewModel.LoadZonesCommand}"
            IsEnabled="{x:Bind ViewModel.CanLoadZones, Mode=OneWay}"
          />
          <TextBox
            Width="220"
            PlaceholderText="Filter zones..."
            Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
          />
          <Button
            Content="Select All"
            Command="{x:Bind ViewModel.SelectAllCommand}"
            IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
          />
          <Button
            Content="Select None"
            Command="{x:Bind ViewModel.SelectNoneCommand}"
            IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
          />
        </StackPanel>
      </Grid>

      <ListView
        Grid.Row="4"
        ItemsSource="{x:Bind ViewModel.VisibleZones, Mode=OneWay}"
        IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
        SelectionMode="None"
        Padding="0"
        MaxWidth="580"
        HorizontalAlignment="Left"
      >
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="vm:ZoneSelection">
            <Grid
              ColumnSpacing="6"
              Padding="0,2"
              Opacity="{x:Bind IsActive, Converter={StaticResource BoolToOpacityConverter}}"
              ToolTipService.ToolTip="{x:Bind ZoneStatus, Converter={StaticResource PurgeTooltipConverter}}"
            >
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <CheckBox
                Grid.Column="0"
                MinWidth="0"
                Padding="0"
                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                IsEnabled="{x:Bind IsActive}"
                Checked="CheckBox_Changed"
                Unchecked="CheckBox_Changed"
              />
              <TextBlock Grid.Column="1" Text="{x:Bind ZoneName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
              <Border
                Grid.Column="2"
                Background="{x:Bind ZoneStatus, Converter={StaticResource StatusToBgConverter}}"
                CornerRadius="4"
                Padding="8,2"
                VerticalAlignment="Center"
              >
                <TextBlock
                  Text="{x:Bind ZoneStatus}"
                  Foreground="{x:Bind ZoneStatus, Converter={StaticResource StatusToFgConverter}}"
                  FontSize="11"
                  FontWeight="SemiBold"
                />
              </Border>
              <FontIcon
                Grid.Column="3"
                Glyph="&#xE73E;"
                Visibility="{x:Bind IsPurged, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                Foreground="Green"
              />
              <TextBlock
                Grid.Column="4"
                Text="{x:Bind StatusText}"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords"
              />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <StackPanel
        Grid.Row="5"
        Spacing="8"
        Visibility="{x:Bind ViewModel.ShowProgress, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
      >
        <ProgressBar
          Minimum="0"
          Maximum="{x:Bind ViewModel.ProgressMaximum, Mode=OneWay}"
          Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
        />
        <TextBlock
          Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        />
      </StackPanel>

      <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8">
        <Button
          Content="Purge Selected"
          Style="{StaticResource AccentButtonStyle}"
          Click="PurgeButton_Click"
          IsEnabled="{x:Bind ViewModel.CanPurge, Mode=OneWay}"
        />
        <Button
          Content="Cancel"
          Command="{x:Bind ViewModel.CancelBatchCommand}"
          Visibility="{x:Bind ViewModel.CanCancel, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
