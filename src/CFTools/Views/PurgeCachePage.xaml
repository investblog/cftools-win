<Page
  x:Class="CFTools.Views.PurgeCachePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:CFTools.ViewModels"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ProgressBar
      Grid.Row="0"
      IsIndeterminate="True"
      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
    />

    <Grid Grid.Row="1" Padding="24" RowSpacing="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Purge Cache" Style="{StaticResource TitleTextBlockStyle}" />

      <TextBlock
        Grid.Row="1"
        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        TextWrapping="WrapWholeWords"
      />

      <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
        <Button
          Content="Load Zones"
          Style="{StaticResource AccentButtonStyle}"
          Command="{x:Bind ViewModel.LoadZonesCommand}"
          IsEnabled="{x:Bind ViewModel.CanLoadZones, Mode=OneWay}"
        />
        <TextBox
          Width="220"
          PlaceholderText="Filter zones..."
          Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
        />
        <Button
          Content="Select All"
          Command="{x:Bind ViewModel.SelectAllCommand}"
          IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
        />
        <Button
          Content="Select None"
          Command="{x:Bind ViewModel.SelectNoneCommand}"
          IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
        />
      </StackPanel>

      <ListView
        Grid.Row="3"
        ItemsSource="{x:Bind ViewModel.VisibleZones, Mode=OneWay}"
        IsEnabled="{x:Bind ViewModel.CanChangeSelection, Mode=OneWay}"
        SelectionMode="None"
      >
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="vm:ZoneSelection">
            <Grid ColumnSpacing="12" Padding="4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
              </Grid.ColumnDefinitions>
              <CheckBox
                Grid.Column="0"
                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                Checked="CheckBox_Changed"
                Unchecked="CheckBox_Changed"
              />
              <TextBlock Grid.Column="1" Text="{x:Bind Zone.Name}" VerticalAlignment="Center" />
              <FontIcon
                Grid.Column="2"
                Glyph="&#xE73E;"
                Visibility="{x:Bind IsPurged, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                Foreground="Green"
              />
              <TextBlock
                Grid.Column="3"
                Text="{x:Bind StatusText}"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords"
              />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <StackPanel
        Grid.Row="4"
        Spacing="8"
        Visibility="{x:Bind ViewModel.ShowProgress, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
      >
        <ProgressBar
          Minimum="0"
          Maximum="{x:Bind ViewModel.ProgressMaximum, Mode=OneWay}"
          Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
        />
        <TextBlock
          Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        />
      </StackPanel>

      <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8">
        <Button
          Content="Purge Selected"
          Style="{StaticResource AccentButtonStyle}"
          Command="{x:Bind ViewModel.PurgeSelectedCommand}"
          IsEnabled="{x:Bind ViewModel.CanPurge, Mode=OneWay}"
        />
        <Button
          Content="Cancel"
          Command="{x:Bind ViewModel.CancelBatchCommand}"
          IsEnabled="{x:Bind ViewModel.CanCancel, Mode=OneWay}"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
