<Page
    x:Class="CFTools.Views.PurgeCachePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CFTools.ViewModels">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Purge Cache" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Load + filter bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Load Zones" Command="{x:Bind ViewModel.LoadZonesCommand}" />
            <Button Content="Select All" Command="{x:Bind ViewModel.SelectAllCommand}" />
            <Button Content="Select None" Command="{x:Bind ViewModel.SelectNoneCommand}" />
            <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="20" Height="20" />
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Zone list -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.Zones, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ZoneSelection">
                    <Grid ColumnSpacing="8" Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Zone.Name}" VerticalAlignment="Center" />
                        <FontIcon Grid.Column="2" Glyph="&#xE73E;"
                                  Visibility="{x:Bind IsPurged, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                                  Foreground="Green" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Progress -->
        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- Purge button -->
        <Button Grid.Row="4" Content="Purge Selected" Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.PurgeSelectedCommand}"
                IsEnabled="{x:Bind ViewModel.CanPurge, Mode=OneWay}" />
    </Grid>
</Page>
