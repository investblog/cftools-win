<Page
  x:Class="CFTools.Views.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <ScrollViewer>
    <StackPanel Padding="16" Spacing="24" MaxWidth="480" HorizontalAlignment="Left">
      <!-- Force StackPanel to match Auth/About width -->
      <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" MinWidth="448" />

      <!-- Request Pool -->
      <StackPanel Spacing="16">
        <TextBlock Text="Request Pool" Style="{StaticResource SubtitleTextBlockStyle}" />

        <Slider
          Header="Max Concurrency"
          Minimum="1"
          Maximum="8"
          SnapsTo="StepValues"
          StepFrequency="1"
          TickFrequency="1"
          TickPlacement="Outside"
          HorizontalAlignment="Stretch"
          Value="{x:Bind ViewModel.MaxConcurrency, Mode=TwoWay}"
        />

        <Slider
          Header="Max Retries"
          Minimum="0"
          Maximum="5"
          SnapsTo="StepValues"
          StepFrequency="1"
          TickFrequency="1"
          TickPlacement="Outside"
          HorizontalAlignment="Stretch"
          Value="{x:Bind ViewModel.MaxRetries, Mode=TwoWay}"
        />
      </StackPanel>

      <!-- Appearance -->
      <StackPanel Spacing="12">
        <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" />

        <ComboBox
          Header="Theme"
          SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
          Width="200"
        >
          <ComboBoxItem Content="System" />
          <ComboBoxItem Content="Light" />
          <ComboBoxItem Content="Dark" />
        </ComboBox>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Page>
