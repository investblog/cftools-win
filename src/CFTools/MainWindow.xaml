<Window
  x:Class="CFTools.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Cloudflare Tools"
>
  <Grid>
    <NavigationView
      x:Name="NavView"
      IsBackButtonVisible="Collapsed"
      PaneDisplayMode="LeftCompact"
      SelectionChanged="NavView_SelectionChanged"
    >
      <NavigationView.MenuItems>
        <NavigationViewItem Content="Add Domains" Tag="AddDomains">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE774;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Purge Cache" Tag="PurgeCache">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE72C;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Delete Domains" Tag="DeleteDomains">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE74D;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <NavigationView.FooterMenuItems>
        <NavigationViewItem
          x:Name="AuthNavItem"
          Tag="Auth"
          Content="Not connected"
          ToolTipService.ToolTip="Not connected"
        >
          <NavigationViewItem.Icon>
            <FontIcon x:Name="AuthIcon" Glyph="&#xE77B;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.FooterMenuItems>

      <Frame x:Name="ContentFrame" />
    </NavigationView>
  </Grid>
</Window>