<Window
  x:Class="CFTools.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="CFTools"
>
  <Grid>
    <NavigationView
      x:Name="NavView"
      IsBackButtonVisible="Collapsed"
      PaneDisplayMode="Left"
      SelectionChanged="NavView_SelectionChanged"
    >
      <NavigationView.MenuItems>
        <NavigationViewItem Content="Add Domains" Tag="AddDomains">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Add" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Purge Cache" Tag="PurgeCache">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Refresh" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Delete Domains" Tag="DeleteDomains">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Delete" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <NavigationView.FooterMenuItems>
        <NavigationViewItem x:Name="AuthNavItem" Content="Not connected" Tag="Auth">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Contact" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.FooterMenuItems>

      <Frame x:Name="ContentFrame" />
    </NavigationView>
  </Grid>
</Window>
