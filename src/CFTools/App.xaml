<Application
  x:Class="CFTools.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:conv="using:CFTools.Converters"
>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
      </ResourceDictionary.MergedDictionaries>
      <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
      <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisConverter" />
      <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
