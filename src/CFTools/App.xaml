<Application
  x:Class="CFTools.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:conv="using:CFTools.Converters"
>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <ResourceDictionary>
          <!-- Cloudflare brand accent override -->
          <Color x:Key="SystemAccentColor">#F6821F</Color>
          <Color x:Key="SystemAccentColorLight1">#F89A4A</Color>
          <Color x:Key="SystemAccentColorLight2">#FAB273</Color>
          <Color x:Key="SystemAccentColorLight3">#FCCB9D</Color>
          <Color x:Key="SystemAccentColorDark1">#D66E15</Color>
          <Color x:Key="SystemAccentColorDark2">#B55B0D</Color>
          <Color x:Key="SystemAccentColorDark3">#944A07</Color>
        </ResourceDictionary>
      </ResourceDictionary.MergedDictionaries>

      <!-- 301-ui dark theme overrides -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <!-- Backgrounds -->
          <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#111111" />
          <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#111111" />
          <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#101219" />
          <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#101219" />
          <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#181A1F" />
          <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#181A1F" />
          <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#111111" />
          <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="#181A1F" />
          <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="#1F2229" />

          <!-- Text -->
          <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#E7E9EE" />
          <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#A0A4AF" />
          <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#8B8F98" />

          <!-- Controls -->
          <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#1F2229" />
          <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#181A1F" />
          <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#38FFFFFF" />
          <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="#16FFFFFF" />
          <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent" />
          <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#10FFFFFF" />

          <!-- InfoBar -->
          <SolidColorBrush x:Key="InfoBarInformationalSeverityBackgroundBrush" Color="#1F2229" />
          <SolidColorBrush x:Key="InfoBarSuccessSeverityBackgroundBrush" Color="#042C1C" />
          <SolidColorBrush x:Key="InfoBarWarningSeverityBackgroundBrush" Color="#38240A" />
          <SolidColorBrush x:Key="InfoBarErrorSeverityBackgroundBrush" Color="#3D0915" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
      <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
      <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisConverter" />
      <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
      <conv:PreflightStatusTextConverter x:Key="PreflightTextConverter" />
      <conv:PreflightStatusBrushConverter x:Key="PreflightBgConverter" IsBackground="True" />
      <conv:PreflightStatusBrushConverter x:Key="PreflightFgConverter" IsBackground="False" />
      <conv:StatusToBadgeBrushConverter x:Key="StatusToBgConverter" IsBackground="True" />
      <conv:StatusToBadgeBrushConverter x:Key="StatusToFgConverter" IsBackground="False" />
      <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
      <conv:WillCreateToVisibilityConverter x:Key="WillCreateToVisConverter" />
      <conv:PunycodeTooltipConverter x:Key="PunycodeTooltipConverter" />
      <conv:PurgeTooltipConverter x:Key="PurgeTooltipConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
